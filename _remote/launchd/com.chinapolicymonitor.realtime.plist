<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.chinapolicymonitor.realtime</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/sd/miniforge3/bin/python3</string>
        <string>/Users/sd/PycharmProjects/CMM/run_fetch_realtime.py</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/sd/PycharmProjects/CMM</string>

    <!--
        Long-running daemon: ships (AIS every ~60s) + flights (every 60s or 15min).
        KeepAlive ensures launchd restarts it if it crashes.
        RunAtLoad starts it immediately on login / load.
    -->
    <key>KeepAlive</key>
    <true/>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/sd/PycharmProjects/CMM/data/logs/launchd_realtime_stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/sd/PycharmProjects/CMM/data/logs/launchd_realtime_stderr.log</string>
</dict>
</plist>
