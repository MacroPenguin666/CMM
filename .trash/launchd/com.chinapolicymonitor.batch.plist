<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.chinapolicymonitor.batch</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/sd/miniforge3/bin/python3</string>
        <string>/Users/sd/PycharmProjects/CMM/run_fetch_batch.py</string>
        <string>--random-delay</string>
        <string>64800</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/sd/PycharmProjects/CMM</string>

    <!--
        Triggered once per day at 03:00 local time.
        The script sleeps a random 0-18h offset before fetching,
        so actual fetch time varies across the day.
        Replaces com.chinapolicymonitor.macro.plist.
    -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>3</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/sd/PycharmProjects/CMM/data/logs/launchd_batch_stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/sd/PycharmProjects/CMM/data/logs/launchd_batch_stderr.log</string>
</dict>
</plist>
