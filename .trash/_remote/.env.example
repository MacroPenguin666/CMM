# China Customs Scraper — Environment Variables
# Copy this to .env and fill in values

# Path to SQLite database file
# Default: auto-detected Google Drive CMM folder, or ~/customs_exports.db
# DB_PATH=/Users/you/Library/CloudStorage/GoogleDrive-you@gmail.com/My Drive/CMM/customs_exports.db

# HTTP proxy with Chinese IP for accessing stats.customs.gov.cn
# Leave unset until you have a proxy configured
# CUSTOMS_PROXY_URL=http://user:pass@proxy-host:3128

# Scraping behaviour
SCRAPE_DELAY_SECONDS=2.0
SCRAPE_MAX_RETRIES=5
SCRAPE_RETRY_BASE_SECONDS=3.0
SCRAPE_HEADLESS=true
SCRAPE_USE_DYNAMIC=true

# Query endpoint — update after inspecting real site with --debug-browser
QUERY_ENDPOINT=http://stats.customs.gov.cn/indexEn

# Scheduler settings
SCHEDULER_DAY=15
SCHEDULER_HOUR=8
SCHEDULER_TIMEZONE=Asia/Shanghai

# ── Policy Monitor ────────────────────────────────────────────────────────────
# OpenSky Network (flights) — register at opensky-network.org for higher rate limits
# OPENSKY_USERNAME=
# OPENSKY_PASSWORD=

# AISStream (ships) — register at aisstream.io
# AISSTREAM_API_KEY=

# AISHub (ships, alternative) — register at aishub.net
# AISHUB_USERNAME=

# ── Global Macro APIs ─────────────────────────────────────────────────────────
# Destatis GENESIS API — register at https://www-genesis.destatis.de
# DESTATIS_TOKEN=

# FRED API (Federal Reserve) — get a free key at https://fred.stlouisfed.org/docs/api/api_key.html
# FRED_API_KEY=

# UN Comtrade+ API — register at https://comtradedeveloper.un.org
# COMTRADE_API_KEY=

# ECB, IMF, World Bank require no auth — URLs can be overridden if needed
# ECB_BASE_URL=https://data-api.ecb.europa.eu/service/data
# IMF_BASE_URL=https://www.imf.org/external/datamapper/api/v1
# WB_BASE_URL=https://api.worldbank.org/v2/country/all/indicator
# DESTATIS_BASE_URL=https://www-genesis.destatis.de/genesisWS/rest/2020/data/table
# COMTRADE_BASE_URL=https://comtradeapi.un.org/data/v1/get/C/A/HS

# ── Policy Advisor ────────────────────────────────────────────────────────────
# Anthropic API key — required to generate AI policy briefs
# Get one at: https://console.anthropic.com/
# Without this key the advisor will still retrieve and list sources (stub mode)
# ANTHROPIC_API_KEY=
